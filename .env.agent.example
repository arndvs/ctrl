# ============================================================
# Agent-Safe Configuration
# ============================================================
# Copy to ~/dotfiles/secrets/.env.agent and fill in values.
# These are NON-SENSITIVE config values that get sourced into
# the shell globally. AI agents CAN see these — no secrets here.
#
# NEVER put API keys, tokens, or passwords in this file.
# Those go in .env.secrets (process-scoped, never in shell).
# ============================================================

# --- System ---
PYTHONUTF8=1

# --- GitHub ---
GITHUB_USERNAME=

# --- Google Cloud ---
GCP_CREDENTIALS_FILE=~/dotfiles/secrets/your-service-account.json

# --- Citation Builder (non-sensitive) ---
CITATION_IMAP_HOST=imap.gmail.com
CITATION_VERIFICATION_EMAIL=
CITATION_BUSINESS_EMAIL=
CITATION_SPREADSHEET_ID=
CITATION_EMAIL=

# --- GitHub Weekly Digest (non-sensitive) ---
SANITY_PROJECT_ID=
SANITY_DATASET=production
