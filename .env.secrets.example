# ============================================================
# Process-Scoped Secrets
# ============================================================
# Copy to ~/dotfiles/secrets/.env.secrets and fill in values.
# These are SENSITIVE credentials — API keys, tokens, passwords.
#
# NEVER sourced into the shell. Only injected at runtime via:
#   ~/dotfiles/bin/run-with-secrets.sh python my_script.py
#
# Agents CANNOT access these values by design.
# ============================================================

# --- GitHub ---
GITHUB_PACKAGE_REGISTRY_TOKEN=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Citation Builder (sensitive) ---
CITATION_VAULT_KEY=
CITATION_EMAIL_PASSWORD=

# --- GitHub Weekly Digest (sensitive) ---
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
SANITY_TOKEN=

# --- AI Image Generation (uncomment when needed) ---
# REPLICATE_API_TOKEN=
# GLIF_API_TOKEN=
