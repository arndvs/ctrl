{
	// =============================================================================
	// TYPESCRIPT & JAVASCRIPT CONFIGURATION
	// =============================================================================
	"js/ts.tsdk": "node_modules/typescript/lib",
	"js/ts.enablePromptUseWorkspaceTsdk": true,
	"js/ts.preferences.importModuleSpecifier": "non-relative",
	"js/ts.updateImportsOnFileMove.enabled": "always",
	"js/ts.preferences.quoteStyle": "single",
	"js/ts.suggest.paths": false,
	"js/ts.format.enable": false,
	"js/ts.tsserver.experimental.enableProjectDiagnostics": true,
	"js/ts.tsserver.maxTsServerMemory": 4096,
	"js/ts.format.enabled": false,
	"js/ts.implicitProjectConfig.checkJs": true,
	"js/ts.suggest.completeFunctionCalls": true,
	// =============================================================================
	// EDITOR BEHAVIOR & FORMATTING
	// =============================================================================
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	"editor.formatOnSaveTimeout": 750,
	"editor.acceptSuggestionOnEnter": "on",
	"editor.tabCompletion": "on",
	"editor.guides.bracketPairs": false, // File 2 overrides File 1 (was true)
	"editor.bracketPairColorization.independentColorPoolPerBracketType": false,
	"editor.minimap.enabled": false,
	"editor.stickyScroll.enabled": false,
	"editor.wordWrap": "on",
	"editor.experimentalGpuAcceleration": "on",
	"editor.accessibilitySupport": "off",
	"editor.gotoLocation.multipleDeclarations": "goto",
	"editor.gotoLocation.multipleDefinitions": "goto",
	"editor.gotoLocation.multipleImplementations": "goto",
	"editor.gotoLocation.multipleReferences": "goto",
	"editor.gotoLocation.multipleTypeDefinitions": "goto",
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit",
		"source.organizeImports": "never",
		"source.fixAll.eslint": "explicit"
	},
	// =============================================================================
	// PRETTIER CONFIGURATION
	// =============================================================================
	"prettier.enable": true,
	"prettier.requireConfig": false,
	"prettier.useEditorConfig": true,
	"prettier.resolveGlobalModules": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"formate.enable": false,
	// =============================================================================
	// LANGUAGE-SPECIFIC FORMATTERS
	// =============================================================================
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"[typescript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true,
		"editor.formatOnSaveMode": "file"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true,
		"editor.formatOnSaveMode": "file"
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	// =============================================================================
	// TAILWIND CSS CONFIGURATION
	// =============================================================================
	"tailwindCSS.files.exclude": [
		"**/.nx/cache/**",
		"**/node_modules/**",
		"**/.git/**",
		"**/dist/**",
		"**/build/**",
		"**/.next/**"
	],
	"tailwindCSS.includeLanguages": {
		"css": "css"
	},
	// =============================================================================
	// CSS CONFIGURATION
	// =============================================================================
	"css.validate": false,
	"less.validate": false,
	"scss.validate": false,
	"css.customData": [
		".vscode/css_custom_data.json"
	],
	// =============================================================================
	// EMMET CONFIGURATION
	// =============================================================================
	"emmet.triggerExpansionOnTab": true,
	"emmet.includeLanguages": {
		"javascript": "javascriptreact"
	},
	"emmet.syntaxProfiles": {
		"xml": {
			"attr_quotes": "single"
		},
		"html": {
			"attr_quotes": "single"
		},
		"js": {
			"attr_quotes": "single",
			"self_closing_tag": true
		},
		"jsx": {
			"attr_quotes": "single",
			"self_closing_tag": true
		}
	},
	// =============================================================================
	// ESLINT CONFIGURATION
	// =============================================================================
	"eslint.validate": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact"
	],
	"eslint.format.enable": false,
	// =============================================================================
	// GITHUB COPILOT & CLAUDE / AI CONFIGURATION
	// =============================================================================
	"github.copilot.enable": {
		"markdown": true
	},
	"github.copilot.nextEditSuggestions.enabled": true,
	"github.copilot.nextEditSuggestions.extendedRange": true,
	"github.copilot.chat.advanced.debug.overrideChatMaxTokenNum": 1000000,
	"github.copilot.chat.advanced.workspace.codeSearchExternalIngest.enabled": "force",
	"github.copilot.chat.agent.omitFileAttachmentContents": true,
	"github.copilot.chat.agent.temperature": 1,
	"github.copilot.chat.agent.largeToolResultsToDisk.enabled": false,
	"github.copilot.chat.agentHistorySummarizationWithPromptCache": true,
	"github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
	"github.copilot.chat.alternateGptPrompt.enabled": true,
	"github.copilot.chat.anthropic.thinking.budgetTokens": 32000,
	"github.copilot.chat.anthropic.thinking.effort": "high",
	"github.copilot.chat.anthropic.toolSearchTool.enabled": true,
	"github.copilot.chat.anthropic.toolSearchTool.mode": "server",
	"github.copilot.chat.anthropic.tools.websearch.enabled": true,
	"github.copilot.chat.anthropic.tools.websearch.maxUses": 20,
	"github.copilot.chat.anthropic.tools.websearch.userLocation": {},
	"github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
	"github.copilot.chat.cli.branchSupport.enabled": true,
	"github.copilot.chat.cli.customAgents.enabled": true,
	"github.copilot.chat.cli.mcp.enabled": true,
	"github.copilot.chat.cli.sessionController.enabled": true,
	"github.copilot.chat.codesearch.enabled": true,
	"github.copilot.chat.customAgents.showOrganizationAndEnterpriseAgents": true,
	"github.copilot.chat.editRecording.enabled": true,
	"github.copilot.chat.edits.gemini3MultiReplaceString": true,
	"github.copilot.chat.enableUserPreferences": true,
	"github.copilot.chat.exploreAgent.model": "claude-opus-4-6",
	"github.copilot.chat.feedback.onChange": true,
	"github.copilot.chat.getSearchViewResultsSkill.enabled": true,
	"github.copilot.chat.githubMcpServer.enabled": true,
	"github.copilot.chat.gpt5AlternativePatch": true,
	"github.copilot.chat.growthMessages.enabled": false,
	"github.copilot.chat.inlineEdits.chatSessionContextProvider.enabled": true,
	"github.copilot.chat.inlineEdits.diagnosticsContextProvider.enabled": true,
	"github.copilot.chat.inlineEdits.nextCursorPrediction.currentFileMaxTokens": 32000,
	"github.copilot.chat.languageContext.fix.typescript.enabled": true,
	"github.copilot.chat.languageContext.inline.typescript.enabled": true,
	"github.copilot.chat.languageContext.typescript.enabled": true,
	"github.copilot.chat.languageContext.typescript.includeDocumentation": true,
	"github.copilot.chat.localWorkspaceRecording.enabled": true,
	"github.copilot.chat.newWorkspace.useContext7": true,
	"github.copilot.chat.notebook.alternativeNESFormat.enabled": true,
	"github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
	"github.copilot.chat.notebook.followCellExecution.enabled": true,
	"github.copilot.chat.notebook.summaryExperimentEnabled": true,
	"github.copilot.chat.otel.captureContent": false,
	"github.copilot.chat.otel.enabled": false,
	"github.copilot.chat.projectLabels.chat": true,
	"github.copilot.chat.projectLabels.expanded": true,
	"github.copilot.chat.projectLabels.inline": true,
	"github.copilot.chat.responsesApiReasoningEffort": "xhigh",
	"github.copilot.chat.review.intent": true,
	"github.copilot.chat.reviewSelection.instructions": [
		{
			"text": "Never flag API payload key mismatches unless the API handler code is visible in the selection. Never infer expected key names from unrelated variables. Focus only on bugs provable from the visible code."
		}
	],
	"github.copilot.chat.scopeSelection": true,
	"github.copilot.chat.searchSubagent.enabled": true,
	"github.copilot.chat.searchSubagent.toolCallLimit": 1000,
	"github.copilot.chat.searchSubagent.useAgenticProxy": true,
	"github.copilot.chat.suggestRelatedFilesFromGitHistory.useEmbeddings": true,
	"github.copilot.chat.tools.defaultToolsGrouped": true,
	"github.copilot.chat.updated53CodexPrompt.enabled": true,
	"github.copilot.chat.useResponsesApiTruncation": true,
	// =============================================================================
	// CHAT / AGENT CONFIGURATION
	// =============================================================================
	"chat.agent.maxRequests": 100000,
	"chat.agent.thinking.collapsedTools": "withThinking",
	"chat.agent.thinkingStyle": "collapsedPreview",
	"chat.agentSessionProjection.enabled": true,
	"chat.checkpoints.showFileChanges": true,
	"chat.customAgentInSubagent.enabled": true,
	"chat.editor.wordWrap": "on",
	"chat.editMode.hidden": true,
	"chat.edits2.enabled": true,
	"chat.experimental.useSkillAdherencePrompt": true,
	"chat.exploreAgent.defaultModel": "Claude Opus 4.6 (copilot)",
	"chat.includeReferencedInstructions": true,
	"chat.instructionsFilesLocations": {
		"~/dotfiles": true,
		".github/instructions": true
	},
	"chat.mcp.discovery.enabled": {
		"claude-desktop": true,
		"cursor-global": true,
		"cursor-workspace": true
	},
	"chat.mcp.serverSampling": {
		"Global in Code - Insiders: canva": {
			"allowedModels": [
				"copilot/claude-opus-4.6-fast"
			]
		},
		"GitHub: GitHub": {
			"allowedModels": [
				"copilot/claude-opus-4.6-fast"
			]
		},
		"Global in Code - Insiders: io.github.tavily-ai/tavily-mcp": {
			"allowedModels": [
				"copilot/claude-opus-4.6-fast"
			]
		}
	},
	"chat.planAgent.defaultModel": "Claude Opus 4.6 (copilot)",
	"chat.requestQueuing.defaultAction": "queue",
	"chat.tips.enabled": true,
	"chat.tools.global.autoApprove": true,
	"chat.tools.terminal.autoReplyToPrompts": true,
	"chat.useAgentSkills": true,
	"chat.useClaudeHooks": true,
	"chat.useCustomAgentHooks": true,
	"chat.useCustomizationsInParentRepositories": true,
	"chat.useNestedAgentsMdFiles": true,
	"chat.viewProgressBadge.enabled": true,
	// =============================================================================
	// CLAUDE CODE CONFIGURATION
	// =============================================================================
	"claudeCode.allowDangerouslySkipPermissions": true,
	"claudeCode.initialPermissionMode": "bypassPermissions",
	"claudeCode.preferredLocation": "sidebar",
	"claudeCode.selectedModel": "default",
	// =============================================================================
	// ROO CODE CONFIGURATION
	// =============================================================================
	"roo-code-nightly.debug": false,
	"roo-code-nightly.allowedCommands": [
		"*",
		"git log",
		"git diff",
		"git show"
	],
	"roo-code-nightly.deniedCommands": [],
	"roo-code-nightly.maximumIndexedFilesForFileSearch": 100000,
	// =============================================================================
	// GIT CONFIGURATION
	// =============================================================================
	"git.rebaseWhenSync": false,
	"git.autofetch": true,
	"git.enableSmartCommit": true,
	"git.decorations.enabled": false,
	// =============================================================================
	// TERMINAL CONFIGURATION
	// =============================================================================
	"terminal.integrated.splitCwd": "initial",
	"terminal.integrated.defaultProfile.windows": "Git Bash",
	"terminal.integrated.enableKittyKeyboardProtocol": true,
	"terminal.integrated.enableImages": true,
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.initialHint": false,
	"terminal.integrated.localEchoEnabled": "auto",
	"terminal.integrated.shellIntegration.enabled": true,
	"terminal.integrated.shellIntegration.history": 1000,
	"terminal.integrated.stickyScroll.enabled": false,
	"terminal.integrated.suggest.providers": {
		"lsp": true
	},
	// =============================================================================
	// FILE & SEARCH CONFIGURATION
	// =============================================================================
	"files.associations": {
		"*.tsx": "typescriptreact",
		"*.ts": "typescript"
	},
	"files.exclude": {
		"**/.classpath": true,
		"**/.project": true,
		"**/.settings": true,
		"**/.idea": true,
		"**/target": true,
		"**/.claude/**": true,
		"**/vendor/**": true,
		"**/.gitattributes": true,
		"**/composer.lock": true
	},
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.next/**": true,
		"**/node_modules/**": true,
		"**/.turbo/**": true
	},
	"search.exclude": {
		"**/.next": true,
		"**/node_modules": true,
		"**/.turbo": true,
		"**/pnpm-lock.yaml": true
	},
	// =============================================================================
	// DIFF EDITOR CONFIGURATION
	// =============================================================================
	"diffEditor.codeLens": true,
	"diffEditor.experimental.showMoves": true,
	"diffEditor.ignoreTrimWhitespace": false,
	"diffEditor.maxComputationTime": 0,
	"diffEditor.renderSideBySide": false,
	// =============================================================================
	// WORKBENCH & UI CUSTOMIZATION
	// =============================================================================
	"workbench.colorTheme": "IBM Carbon Color Theme",
	"workbench.colorCustomizations": {
		"editorStickyScroll.background": "#232323",
		"editorStickyScrollHover.background": "#333333"
	},
	"workbench.browser.enableChatTools": true,
	"workbench.browser.openLocalhostLinks": true,
	"workbench.editor.allowOpenInModalEditor": false,
	"workbench.editor.enablePreview": false,
	"workbench.editor.useModal": "off",
	"workbench.enableExperiments": false,
	"workbench.navigationControl.enabled": false,
	"workbench.startupEditor": "none",
	"workbench.statusBar.visible": false,
	"workbench.tree.enableStickyScroll": false,
	// =============================================================================
	// MISCELLANEOUS SETTINGS
	// =============================================================================
	"npm.packageManager": "npm",
	"yaml.format.singleQuote": true,
	"nxConsole.generateAiAgentRules": true,
	"enable-crash-reporter": false,
	"explorer.autoReveal": false,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmPasteNative": false,
	"inlineChat.affordance": "editor",
	"inlineChat.defaultModel": "Claude Opus 4.6 (copilot)",
	"inlineChat.enableV2": true,
	"intelephense.compatibility.correctForArrayAccessArrayAndTraversableArrayUnionTypes": false,
	"redhat.telemetry.enabled": false,
	"scm.diffDecorations": "none",
	"scm.diffDecorationsGutterAction": "none",
	"scm.diffDecorationsGutterVisibility": "hover",
	"simpleBrowser.useIntegratedBrowser": true,
	"task.allowAutomaticTasks": "on",
	"telemetry.disableFeedback": true,
	"telemetry.editStats.enabled": false,
	"telemetry.feedback.enabled": false,
	"telemetry.telemetryLevel": "off",
	"testing.gutterEnabled": false,
	"workbench.secondarySideBar.showLabels": false,
	"gitlens.ai.model": "vscode",
	"gitlens.ai.vscode.model": "copilot:gpt-4.1",
	"workbench.sideBar.location": "right",
	"git.confirmSync": false,
	"github.copilot.chat.agentDebugLog.enabled": true,
	"github.copilot.chat.agentDebugLog.fileLogging.enabled": true
}