# ============================================================
# DEPRECATED — Use .env.agent.example and .env.secrets.example
# ============================================================
# This file is kept for reference during migration.
# Non-sensitive config → secrets/.env.agent (from .env.agent.example)
# Credentials/tokens  → secrets/.env.secrets (from .env.secrets.example)
#
# After migrating, delete this file and secrets/.env.
# ============================================================

# --- System ---
PYTHONUTF8=1

# --- GitHub ---
GITHUB_USERNAME=
GITHUB_PACKAGE_REGISTRY_TOKEN=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Cloud ---
GCP_CREDENTIALS_FILE=~/dotfiles/secrets/your-service-account.json

# --- Citation Builder ---
CITATION_VAULT_KEY=
CITATION_EMAIL=
CITATION_EMAIL_PASSWORD=
CITATION_IMAP_HOST=imap.gmail.com
CITATION_VERIFICATION_EMAIL=
CITATION_BUSINESS_EMAIL=
CITATION_SPREADSHEET_ID=

# --- AI Image Generation (uncomment when needed) ---
# REPLICATE_API_TOKEN=
# GLIF_API_TOKEN=

# --- Nanobot (optional) ---
# NANOBOT_OPENAI_KEY=
