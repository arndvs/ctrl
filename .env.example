# ============================================================
# Dotfiles Centralized Secrets
# ============================================================
# Copy this file to ~/dotfiles/secrets/.env and fill in values.
# This file is the SINGLE SOURCE OF TRUTH for all API keys,
# tokens, and credentials across all skills and scripts.
#
# NEVER commit .env — only .env.example is tracked in git.
# ============================================================

# --- System ---
PYTHONUTF8=1

# --- GitHub ---
GITHUB_USERNAME=
GITHUB_PACKAGE_REGISTRY_TOKEN=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Cloud ---
GCP_CREDENTIALS_FILE=$HOME/dotfiles/secrets/your-service-account.json

# --- Citation Builder ---
CITATION_VAULT_KEY=
CITATION_EMAIL=
CITATION_EMAIL_PASSWORD=
CITATION_IMAP_HOST=imap.gmail.com
CITATION_VERIFICATION_EMAIL=
CITATION_BUSINESS_EMAIL=
CITATION_SPREADSHEET_ID=

# --- AI Image Generation (uncomment when needed) ---
# REPLICATE_API_TOKEN=
# GLIF_API_TOKEN=

# --- Nanobot (optional) ---
# NANOBOT_OPENAI_KEY=
