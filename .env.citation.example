# ============================================================
# Citation Builder — Additional Secrets
# ============================================================
# Copy this file to ~/dotfiles/secrets/.env.citation and fill in values.
# These supplement the main secrets/.env variables.
# Only needed if you use the citation-builder-skill.
#
# NEVER commit .env.citation — only .env.citation.example is tracked in git.
# ============================================================

# --- Credential Vault ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CITATION_VAULT_KEY=

# --- Email for Verifications (IMAP mode) ---
CITATION_EMAIL=
CITATION_EMAIL_PASSWORD=
CITATION_IMAP_HOST=imap.gmail.com

# --- Email Accounts ---
CITATION_VERIFICATION_EMAIL=
CITATION_BUSINESS_EMAIL=

# --- Google Sheets ---
CITATION_SPREADSHEET_ID=
